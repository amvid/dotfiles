{
  "cli_default_open_behavior": "new_window",
  "edit_predictions": {
    "provider": "zed",
  },
  "git_panel": {
    "dock": "left",
  },
  "agent": {
    "sidebar_side": "right",
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
  },
  "icon_theme": {
    "mode": "dark",
    "light": "JetBrains New UI Icons (Dark)",
    "dark": "JetBrains New UI Icons (Dark)",
  },
  "project_panel": {
    "dock": "left",
  },
  "base_keymap": "VSCode",
  "ui_font_size": 13,
  "buffer_font_size": 11,
  "terminal": {
    "font_size": 11,
  },
  "vim_mode": false,
  "theme": "Vercel Dark",
  "languages": {
    "PHP": {
      "language_servers": ["intelephense"],
    },
    "TypeScript": {
      "language_servers": ["typescript-language-server", "!vtsls", "!eslint"],
      "formatter": "language_server",
    },
    "TSX": {
      "language_servers": [
        "!deno",
        "typescript-language-server",
        "!vtsls",
        "!eslint",
      ],
      "formatter": "language_server",
    },
  },
}
