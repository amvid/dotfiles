{
  "base_keymap": "JetBrains",
  "ui_font_size": 13,
  "buffer_font_size": 12,
  "terminal": {
    "font_size": 12
  },
  "vim_mode": false,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Ayu Dark"
  },
  "languages": {
    "PHP": {
      "language_servers": ["intelephense"]
    },
    "TypeScript": {
      "language_servers": ["!typescript-language-server", "!vtsls", "!eslint"],
      "formatter": "language_server"
    },
    "TSX": {
      "language_servers": [
        "deno",
        "!typescript-language-server",
        "!vtsls",
        "!eslint"
      ],
      "formatter": "language_server"
    }
  }
}
